<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Консоль -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{15}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Основной файл логов -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/wiper-service.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/wiper-service-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Логи безопасности -->
    <appender name="SECURITY" class="ch.qos.logback.core.FileAppender">
        <file>logs/security.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Telegram логи -->
    <appender name="TELEGRAM" class="ch.qos.logback.core.FileAppender">
        <file>logs/telegram.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- CRUD логи -->
    <appender name="CRUD" class="ch.qos.logback.core.FileAppender">
        <file>logs/crud.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Логи ошибок -->
    <appender name="ERROR" class="ch.qos.logback.core.FileAppender">
        <file>logs/error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Security логи -->
    <logger name="com.example.wiperservice.config" level="INFO" additivity="false">
        <appender-ref ref="SECURITY"/>
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="com.example.wiperservice.controller.AuthController" level="INFO" additivity="false">
        <appender-ref ref="SECURITY"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- CRUD логи -->
    <logger name="com.example.wiperservice.controller.WiperController" level="INFO" additivity="false">
        <appender-ref ref="CRUD"/>
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="com.example.wiperservice.service.WiperService" level="INFO" additivity="false">
        <appender-ref ref="CRUD"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Telegram логи -->
    <logger name="com.example.wiperservice.controller.TelegramController" level="INFO" additivity="false">
        <appender-ref ref="TELEGRAM"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Корневой логгер -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR"/>
    </root>
</configuration>